{
  "name": "dev-assistant-cli",
  "version": "1.0.0",
  "description": "AI-powered dev assistant for your codebase — powered by Groq",
  "type": "module",
  "bin": {
    "dev-assist": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "postbuild": "node -e \"const fs=require('fs');try{fs.chmodSync('dist/index.js','755')}catch(e){}\""
  },
  "keywords": ["cli", "ai", "developer", "groq", "codebase", "assistant"],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "chalk": "^5.3.0",
    "commander": "^12.0.0",
    "fs-extra": "^11.2.0",
    "glob": "^11.0.0",
    "groq-sdk": "^0.7.0",
    "inquirer": "^9.2.15",
    "ora": "^8.0.1"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "@types/inquirer": "^9.0.7",
    "@types/node": "^20.11.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3"
  }
}
